{{!< ./default}} <main id="site-main" class="site-main site-signup outer">
    <div class="membership-container">
        <form data-members-form data-members-autoredirect="false" id="signup-form">
            <div class="form-header">
                {{#unless @member}}
                <div class="signup-header">
                    <h1 class="signup-title">Become a Member</h1>
                </div>
                <div class="input-container">
                    <label class="name-input">
                        Name
                        <input id="name" data-members-name placeholder="Craig Mod" required="true" />
                    </label>
                    <label class="email-input">
                        Email
                        <input id="signup-email" data-members-email type="email" required="true"
                            placeholder="craigmod@theteastand.org" />
                    </label>
                    <div id="error" class="error-container" data-members-error></div>
                </div>
                <div id="signup-description" class="signup-description">
                </div>
                {{else }}
                <h1 class="choose-plan-header">Choose a plan</h1>
                <span id="signup-name" style="display: none;"></span>
                <span id="signup-email" style="display: none;">{{@member.email}}</span>
                <span id="membership-paid" style="display: none;">{{@member.paid}}</span>
                {{#foreach @member.subscriptions as |sub|}}
                <span class="member-subscription" style="display:none;">{{sub.tier.name}}</span>
                {{/foreach}}
                {{/unless}}
            </div>
            <section class="membership-plans">
                {{#get "tiers" include="id,name,description,monthly_price,benefits" limit="all" as |tiers|}}
                {{#foreach tiers as |tier|}}
                {{#if monthly_price}}
                {{!-- Paid tier --}}
                <div class="card" id="{{monthly_price}}" data-test-tier="paid">
                    <div class="image-header">
                        <img class="plan-image" src="/assets/images/signup/{{tier.name}}.jpeg" alt="{{name}}" />
                    </div>
                    <div class="card-content">
                        <div class="card-header">
                            <h4 class="plan-name" style="color: {{@site.accent_color}}">{{name}}</h4>
                            <div class="price-container">
                                <span class="price-currency">$</span>
                                <span class="plan-amount title" data-testid="product-amount">{{price
                                    monthly_price}}</span>
                                <span class="billing-period">/month</span>
                            </div>
                        </div>
                        <div class="card-details">
                            <div class="perk-list" id="{{tier.name}}">
                            </div>
                        </div>
                        <div class="plan-button stripe-checkout-link" id="{{name}}-payment-button"
                            style="background-color: {{@site.accent_color}}">Choose Tier</div>
                    </div>
                </div>
                {{/if}}
                {{/foreach}}
                {{/get}}
                {{!-- Pay what you wish --}}
        </form>
        <div class="card" data-test-tier="paid">
            <div class="card-content">
                <div class="spacer"></div>
                <div class="card-header">
                    <h4 class="plan-name" style="color: {{@site.accent_color}}">Pay What You Wish</h4>
                    <div class="plan-description" data-testid="product-description">
                        Choose your own monthly contribution amount and receive the corresponding perks! </div>
                    <div>
                        <form id="pwyw-form">
                            <span class="price-currency">$</span>
                            <input id="subscriptionAmount" class="number-input title" type="number" placeholder="50"
                                required="true" min="1" />
                            <span class="billing-period">/month</span>
                        </form>
                    </div>
                </div>
                <div class="card-details">
                </div>
                <div id="pwyw-payment-button" class="plan-button" style="background-color: {{@site.accent_color}}">
                    Choose
                    Tier
                </div>
            </div>
        </div>
        </section>
        {{#if @member.paid}}
        <div class="cancellation-layout" {{#foreach @member.subscriptions as |sub|}} <div
            class="cancellation-container">
            {{cancel_link class="cancel-link" cancelLabel="Cancel Membership"}}
        </div>
        {{/foreach}}
    </div>
    {{/if}}
    <div class="members-description-container">
        <div id="members-description" class="members-description">
        </div>
    </div>
    </div>
    </main>

    <script src="{{asset 'js/settings.js'}}"></script>
    <script src="{{asset 'js/signup.js'}}"></script>

    <script type="text/javascript">
        // Redirect to success page on successful free tier signup
        function connectMutationObserver() {
            const targetNode = document.getElementById("signup-form");
            const config = { attributes: true, childList: false, subtree: false };

            // Only free tier can trigger this callback
            const callback = (mutationList, observer) => {
                for (const mutation of mutationList) {
                    if (mutation.type === "attributes") {
                        if (mutation.target.className === 'success') {
                            document.location = '/signup-success'
                        }
                    }
                }
            };

            const observer = new MutationObserver(callback);
            observer.observe(targetNode, config);
        }

        function getStripeLink(subscriptionAmount, payWhatYouWish) {
            subscriptionAmount = subscriptionAmount || document.getElementById("subscriptionAmount").value;
            var emailNode = document.getElementById("signup-email");
            var email = emailNode.value || emailNode.innerHTML;
            // no email or no price : ask user to fill all
            var form = document.getElementById('signup-form')
            const formValid = form.reportValidity()
            if (!email || !formValid) {
                return;
            }
            if (payWhatYouWish) {
                const pwywForm = document.getElementById('pwyw-form')
                const pwywFormValid = pwywForm.reportValidity()
                if (!pwywFormValid) {
                    return
                }
            }
            // Existing paying members switch (overwrite) their current subscription instead of
            // creating a new one, which would double-charge them.
            var paidNode = document.getElementById("membership-paid")
            var isPaid = paidNode && paidNode.innerHTML.trim() === "true"
            if (isPaid) {
                var confirmed = window.confirm(
                    "Switch your membership to $" + subscriptionAmount +
                    "/month now? You'll be charged a prorated amount today."
                )
                if (!confirmed) {
                    return
                }
                fetch("https://teastand-backend.vercel.app/api/change-subscription", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "Accept": "*/*"
                    },
                    body: JSON.stringify({ email, amount: subscriptionAmount })
                }).then(function (result) {
                    return result.json()
                }).then(function (json) {
                    // post update redirection
                    document.location = json.url
                })
                return
            }
            // call our custom backend
            fetch("https://teastand-backend.vercel.app/api/get-stripe-session", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Accept": "*/*"
                },
                body: JSON.stringify({ email, amount: subscriptionAmount })
            }).then(function (result) {
                return result.json()
            }).then(function (json) {
                // post payment redirection
                document.location = json.url
            })
        }

        function addClickHandlers() {
            document.getElementById("pwyw-payment-button").addEventListener("click", () => getStripeLink(null, true))
            document.getElementById("Sipper-payment-button").addEventListener("click", () => getStripeLink(3, false))
            document.getElementById("Steeper-payment-button").addEventListener("click", () => getStripeLink(9, false))
            document.getElementById("Big Steeper-payment-button").addEventListener("click", () => getStripeLink(33, false))
            document.getElementById("Mega Steeper-payment-button").addEventListener("click", () => getStripeLink(99, false))
        }

        // Gray out and disable the button for any plan the member is already subscribed to.
        // The `.disabled` CSS class also sets pointer-events:none, so the click handler can't fire.
        function disableSubscribedPlans() {
            document.querySelectorAll(".member-subscription").forEach(function (node) {
                var tierName = node.textContent.trim()
                if (!tierName) {
                    return
                }
                var button = document.getElementById(tierName + "-payment-button")
                if (button) {
                    button.classList.add("disabled")
                    button.textContent = "Current Plan"
                }
            })
        }

        // Disable scroll on PWYW number input
        document.addEventListener("wheel", function (e) {
            if (document.activeElement.type === "number" && document.activeElement === e.target) {
                e.preventDefault();
            }
        }, { passive: false });

        document.addEventListener("DOMContentLoaded", function () {
            addClickHandlers()
            disableSubscribedPlans()
            connectMutationObserver()
        });


    </script>