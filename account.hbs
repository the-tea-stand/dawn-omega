{{!< ./default}}

<main id="site-main" class="site-main site-account outer">
    <div class="account-container">

        {{#unless @member}}
        {{!-- Not logged in --}}
        <div class="account-unauthenticated">
            <h1>Account</h1>
            <p>You need to be signed in to view your account.</p>
            <a class="gh-btn gh-primary-btn" href="#/portal/signin" data-portal="signin">Sign in</a>
        </div>

        {{else}}
        {{!-- Hidden data spans for JS --}}
        <span id="member-email" style="display:none">{{@member.email}}</span>
        <span id="member-paid" style="display:none">{{@member.paid}}</span>
        {{#foreach @member.subscriptions as |sub|}}
        <span class="member-tier-name" style="display:none">{{sub.tier.name}}</span>
        {{/foreach}}

        {{!-- Section 1: Profile --}}
        <section class="account-section">
            <h2>Profile</h2>
            <div class="form-row">
                <label for="account-name">Name</label>
                <input id="account-name" type="text" placeholder="Your name" />
            </div>
            <div class="form-row">
                <label for="account-email">Email</label>
                <input id="account-email" type="email" placeholder="your@email.com" />
                <p class="email-change-note">Changing email sends a verification link to the new address.</p>
            </div>
            <div class="account-actions">
                <button id="save-profile" class="gh-btn gh-primary-btn">Save</button>
            </div>
            <div id="profile-success" class="success-message" style="display:none">Profile updated!</div>
            <div id="profile-error" class="error-message" style="display:none"></div>
        </section>

        {{!-- Section 2: Membership --}}
        <section class="account-section">
            <h2>Membership</h2>

            {{#if @member.paid}}
            <div class="current-plan">
                <p>Current plan: <strong class="current-plan-name"></strong></p>
                <div class="account-actions">
                    <button id="manage-billing" class="gh-btn gh-primary-btn">Manage Billing</button>
                </div>
            </div>
            {{/if}}

            <div class="membership-plans">
                {{#get "tiers" include="id,name,description,monthly_price,benefits" limit="all" as |tiers|}}
                {{#foreach tiers as |tier|}}
                {{#if monthly_price}}
                <div class="card" data-test-tier="paid">
                    <div class="card-header">
                        <h4 class="plan-name" style="color: {{@site.accent_color}}">{{name}}</h4>
                        <div class="price-container">
                            <span class="price-currency">$</span>
                            <span class="plan-amount title" data-testid="product-amount">{{price monthly_price}}</span>
                            <span class="billing-period">/month</span>
                        </div>
                    </div>
                    <div class="card-details">
                        <div class="plan-description" data-testid="product-description">{{description}}</div>
                        <div class="benefit-list">
                            {{#foreach benefits as |benefit|}}
                            <div class="benefit-title">✓ {{benefit}}</div>
                            {{/foreach}}
                        </div>
                    </div>
                    <div class="plan-button stripe-checkout-link" id="{{name}}-payment-button"
                        style="background-color: {{@site.accent_color}}">Choose</div>
                </div>
                {{/if}}
                {{/foreach}}
                {{/get}}

                {{!-- Pay What You Wish --}}
                <div class="card" data-test-tier="paid">
                    <div class="card-header">
                        <h4 class="plan-name" style="color: {{@site.accent_color}}">Pay What You Wish</h4>
                        <div>
                            <form id="pwyw-form">
                                <span class="price-currency">$</span>
                                <input id="subscriptionAmount" class="number-input title" type="number" placeholder="33"
                                    required="true" min="1" />
                                <span class="billing-period">/month</span>
                            </form>
                        </div>
                    </div>
                    <div class="card-details">
                        <div class="plan-description" data-testid="product-description">
                            Choose your own monthly contribution and receive perks!
                        </div>
                        <div class="benefit-list">
                            <div class="benefit-title">✓ $1+/month makes you a Sipper!</div>
                            <div class="benefit-title">✓ $10+/month makes you a Steeper!</div>
                            <div class="benefit-title">✓ $100+/month makes you a Big Steeper!</div>
                        </div>
                    </div>
                    <div id="pwyw-payment-button" class="plan-button" style="background-color: {{@site.accent_color}}">Choose</div>
                </div>
            </div>

            {{#if @member.paid}}
            <div class="cancellation-layout">
                {{#foreach @member.subscriptions as |sub|}}
                <div class="cancellation-container">
                    {{cancel_link class="cancel-link" cancelLabel="Cancel Membership"}}
                </div>
                {{/foreach}}
            </div>
            {{/if}}
        </section>

        {{!-- Section 3: Email Subscriptions --}}
        <section class="account-section">
            <h2>Email Subscriptions</h2>
            <div id="newsletter-list"></div>
            <div class="account-actions">
                <button id="save-newsletters" class="gh-btn gh-primary-btn">Save</button>
            </div>
            <div id="newsletter-success" class="success-message" style="display:none">Preferences saved!</div>
            <div id="newsletter-error" class="error-message" style="display:none"></div>
        </section>

        {{/unless}}
    </div>
</main>

<script src="{{asset 'js/account.js'}}"></script>
